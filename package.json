{
	"name": "doctor-json",
	"version": "0.0.0-semantic-release",
	"description": "Surgically edit JSON & JSONC strings while preserving whitespace, comments, and formatting",
	"keywords": [
		"json",
		"jsonc",
		"edit",
		"ast",
		"preserve",
		"whitespace",
		"comments"
	],
	"license": "MIT",
	"author": "Hiroki Osame",
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		"types": "./dist/index.d.mts",
		"default": "./dist/index.mjs"
	},
	"packageManager": "pnpm@10.20.0",
	"scripts": {
		"build": "pkgroll",
		"lint": "lintroll --cache .",
		"test": "node tests/index.ts",
		"type-check": "tsc",
		"prepack": "pnpm build && clean-pkg-json"
	},
	"dependencies": {
		"@humanwhocodes/momoa": "^3.3.10"
	},
	"devDependencies": {
		"@types/node": "^25.3.3",
		"clean-pkg-json": "^1.3.0",
		"lintroll": "^1.30.0",
		"manten": "2.0.0",
		"pkgroll": "^2.26.3",
		"typescript": "^5.9.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
